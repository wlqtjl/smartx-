{
  "name": "smartx-migration-server",
  "private": true,
  "version": "0.1.0",
  "description": "《数据中心攻坚战》SmartX V2V 迁移 — 服务端（权威模拟 + REST + WebSocket）",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/server/src/index.js",
    "start:tsx": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json --resolve-full-paths && node scripts/copy-migrations.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test --import tsx/esm tests/*.test.ts",
    "db:migrate": "tsx src/storage/dbCli.ts migrate",
    "db:migrate:down": "tsx src/storage/dbCli.ts migrate:down",
    "db:status": "tsx src/storage/dbCli.ts status",
    "db:seed": "tsx src/storage/dbCli.ts seed",
    "import:json": "tsx src/storage/dbCli.ts import:json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "cors": "2.8.5",
    "express": "4.21.2",
    "express-rate-limit": "^7.4.1",
    "pg": "^8.13.1",
    "ws": "8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.10",
    "tsc-alias": "^1.8.10",
    "tsx": "4.19.2",
    "typescript": "^5.4.5"
  }
}
