# SmartX 服务端 / 客户端环境变量示例
#
# 复制为 `.env` 供 `docker compose` 使用，或按需导出到运行环境。
# 所有不以 `#` 开头的值会被 docker-compose / 本仓库脚本读取。

# -------- Server --------
# HTTP + WebSocket 监听端口
SMARTX_PORT=8787
# 绑定地址（容器内保持 0.0.0.0）
SMARTX_HOST=0.0.0.0
# 持久化 JSON 路径（在容器里映射到卷）
SMARTX_DATA_PATH=/data/state.json

# CORS 白名单（逗号分隔）。
# 生产模式（NODE_ENV=production）下若为空，服务端将拒绝启动。
SMARTX_ALLOWED_ORIGINS=http://localhost:8080

# WebSocket Origin 白名单。留空则复用 SMARTX_ALLOWED_ORIGINS。
SMARTX_WS_ALLOWED_ORIGINS=

# 日志级别：debug | info | warn | error
LOG_LEVEL=info

# 可选：速率限制（请求/分钟/IP）。默认 60。
SMARTX_RATE_LIMIT_PER_MIN=60

# 可选：WS 每连接最大订阅任务数。默认 16。
SMARTX_WS_MAX_SUBSCRIPTIONS=16

# 可选：让服务端顺带伺服构建好的前端静态资源（绝对路径）。
# 若设置，访问 / 即可获得 SPA；否则由独立的客户端容器/Nginx 伺服。
# SMARTX_STATIC_ROOT=/app/client-dist

# -------- Client (build-time) --------
# Vite 打包时嵌入的后端 URL。同源部署请留空并启用 Nginx 反代。
VITE_SMARTX_API=http://localhost:8787

# 客户端 Nginx 暴露端口
CLIENT_PORT=8080

# -------- Runtime --------
NODE_ENV=production
