# SmartX 服务端 / 客户端环境变量示例
#
# 复制为 `.env` 供 `docker compose` 使用，或按需导出到运行环境。
# 所有不以 `#` 开头的值会被 docker-compose / 本仓库脚本读取。

# -------- Server --------
# HTTP + WebSocket 监听端口
SMARTX_PORT=8787
# 绑定地址（容器内保持 0.0.0.0）
SMARTX_HOST=0.0.0.0
# 持久化 JSON 路径（在容器里映射到卷）
SMARTX_DATA_PATH=/data/state.json

# -------- Persistence backend (PR #2) --------
# 选择存储后端：json | sqlite | postgres
#   json     单文件快照，仅开发/单实例演示
#   sqlite   better-sqlite3，单节点生产可用（WAL 模式）
#   postgres 多实例生产推荐；需同时设置 DATABASE_URL
# 若留空：有 DATABASE_URL 则默认 postgres，否则默认 json。
SMARTX_STORE=json

# 生产下使用 json 需要显式允许（避免误部署）。sqlite/postgres 忽略此值。
SMARTX_ALLOW_JSON_IN_PROD=1

# SQLite 文件路径（SMARTX_STORE=sqlite 生效）。留空则与 SMARTX_DATA_PATH 同目录。
# SMARTX_SQLITE_PATH=/data/smartx.db

# Postgres 连接串（SMARTX_STORE=postgres 生效）。
# DATABASE_URL=postgres://smartx:smartx@db:5432/smartx

# Postgres 连接池上限，默认 10。
# SMARTX_DB_POOL_MAX=10

# -------- Identity / Auth (PR #1) --------
# 密码 / JWT / OIDC 真实身份。未配置 SMARTX_JWT_SECRET 时仅支持 guest 登录。
#
# 启用密码登录（必需）：
#   1. 设置 SMARTX_JWT_SECRET（>= 32 字符）
#   2. 通过 `POST /api/auth/password/register` 创建用户（或打开自注册）
#   3. 客户端使用 `POST /api/auth/password/login` 拿到 access + refresh JWT
#
# 启用 OIDC：填写 SMARTX_OIDC_ISSUER_URL + CLIENT_ID + CLIENT_SECRET + REDIRECT_URL。
# 未配置则 `/api/auth/oidc/*` 返回 501。
#
# guest 登录（/api/auth/session + X-Session-Token header）仍然可用于开发/演示；
# 生产默认关闭（SMARTX_ALLOW_GUEST_LOGIN=0），如需开放请显式置 1。

# HMAC 签名密钥（HS256）。随机 >=32 字符；可用 `openssl rand -hex 32` 生成。
# 生产若启用密码/OIDC，此项必需；未设置则整个 /api/auth/password/* 与 /oidc/* 都不挂载。
# SMARTX_JWT_SECRET=

# JWT issuer claim（默认 smartx）。
# SMARTX_JWT_ISSUER=smartx

# access / refresh 令牌 TTL（秒）。默认 15min / 30d。
# SMARTX_JWT_ACCESS_TTL_SEC=900
# SMARTX_JWT_REFRESH_TTL_SEC=2592000

# guest 登录（/api/auth/session）开关。dev/test 默认 1；production 默认 0。
# SMARTX_ALLOW_GUEST_LOGIN=1

# 自注册（POST /api/auth/password/register）开关。dev/test 默认 1；production 默认 0。
# 生产建议关闭自注册，改由管理员脚本/内部工具创建用户。
# SMARTX_ALLOW_SELF_REGISTER=0

# OIDC（可选）：留空则 `/api/auth/oidc/*` 返回 501。
# SMARTX_OIDC_ISSUER_URL=https://accounts.example.com
# SMARTX_OIDC_CLIENT_ID=
# SMARTX_OIDC_CLIENT_SECRET=
# SMARTX_OIDC_REDIRECT_URL=https://smartx.example.com/api/auth/oidc/callback
# SMARTX_OIDC_SCOPES=openid profile email
# 将 id_token / userinfo 里的哪个 claim 解析为 roles[]（可选，支持空格/逗号分隔）
# SMARTX_OIDC_ROLE_CLAIM=roles

# -------- docker-compose postgres profile （可选） --------
# 启用：docker compose --profile postgres up
POSTGRES_USER=smartx
POSTGRES_PASSWORD=smartx
POSTGRES_DB=smartx
POSTGRES_PORT=5432

# CORS 白名单（逗号分隔）。
# 生产模式（NODE_ENV=production）下若为空，服务端将拒绝启动。
SMARTX_ALLOWED_ORIGINS=http://localhost:8080

# WebSocket Origin 白名单。留空则复用 SMARTX_ALLOWED_ORIGINS。
SMARTX_WS_ALLOWED_ORIGINS=

# 日志级别：debug | info | warn | error
LOG_LEVEL=info

# 可选：速率限制（请求/分钟/IP）。默认 60。
SMARTX_RATE_LIMIT_PER_MIN=60

# 可选：WS 每连接最大订阅任务数。默认 16。
SMARTX_WS_MAX_SUBSCRIPTIONS=16

# 可选：让服务端顺带伺服构建好的前端静态资源（绝对路径）。
# 若设置，访问 / 即可获得 SPA；否则由独立的客户端容器/Nginx 伺服。
# SMARTX_STATIC_ROOT=/app/client-dist

# -------- Client (build-time) --------
# Vite 打包时嵌入的后端 URL。同源部署请留空并启用 Nginx 反代。
VITE_SMARTX_API=http://localhost:8787

# 客户端 Nginx 暴露端口
CLIENT_PORT=8080

# -------- Runtime --------
NODE_ENV=production
